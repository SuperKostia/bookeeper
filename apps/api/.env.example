NODE_ENV=development
PORT=3001

# Database
DATABASE_URL="postgresql://bookeeper:bookeeper@localhost:5432/bookeeper?schema=public"

# Redis (queues + cache)
REDIS_URL="redis://localhost:6379"

# Auth
JWT_SECRET="change-me-before-prod"

# Twilio Verify (phone OTP)
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_VERIFY_SID=""

# Stripe Connect
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

# Mapbox (geocoding + reverse)
MAPBOX_TOKEN=""

# Cloudflare R2 (photos)
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET="bookeeper-photos"
R2_ENDPOINT=""

# Observability
SENTRY_DSN=""
POSTHOG_KEY=""
